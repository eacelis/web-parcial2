# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api
SWAGGER_ENABLED=true

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=loans
DB_PASSWORD=loans
DB_NAME=loans
# DB_SYNCHRONIZE=true SOLO en desarrollo local — JAMÁS en producción.
# En la evaluación se exige usar migraciones; deje esto en false.
DB_SYNCHRONIZE=false
DB_LOGGING=false

# --- JWT (mínimo 32 caracteres cada uno) ---
JWT_ACCESS_SECRET=change-me-access-secret-must-be-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-must-be-at-least-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# --- Bcrypt ---
BCRYPT_SALT_ROUNDS=10

# --- Reglas de negocio (ver enunciado §4.4) ---
MAX_ACTIVE_LOANS=3
DAILY_FINE_RATE=0.50
MAX_LOAN_DAYS=30
